// HOW TO USE:
//   1. Copy this file → rename the copy to  secrets.h  (same folder as the .ino)
//   2. Fill in your real WiFi names and passwords below
//   3. secrets.h is in .gitignore — it will NEVER be pushed to GitHub
//
// The SCHOOL_WIFI switch in isoclime_esp32.ino picks the right block:
//   #define SCHOOL_WIFI 0  →  uses HOME block below
//   #define SCHOOL_WIFI 1  →  uses SCHOOL block below

#if SCHOOL_WIFI == 0
  // ── Home WiFi (DHCP — router assigns IP automatically) ─────────────────────
  const char* WIFI_SSID = "YOUR_HOME_WIFI_NAME";      // ← your home WiFi name
  const char* WIFI_PASS = "YOUR_HOME_WIFI_PASSWORD";   // ← your home WiFi password
  // No static IP needed at home — leave the lines below commented out.

#else
  // ── School WiFi (static IP — school network won't assign one via DHCP) ──────
  const char* WIFI_SSID = "YOUR_SCHOOL_WIFI_NAME";     // ← school WiFi name
  const char* WIFI_PASS = "YOUR_SCHOOL_WIFI_PASSWORD";  // ← school WiFi password (use "" if open/no password)

  // Static IP config — keeps the ESP32 on a known address at school.
  // The dashboard URL will always be  http://11.0.8.106/
  #define WIFI_STATIC_IP
  static const IPAddress WIFI_LOCAL_IP(11,  0,  8, 106); // this device's fixed IP
  static const IPAddress WIFI_GATEWAY (11,  0, 10,   1); // school router / gateway
  static const IPAddress WIFI_SUBNET  (255, 255, 0,  0); // /16 — covers 11.0.x.x
  static const IPAddress WIFI_DNS1    (11,  0, 10,   1); // use router as primary DNS
  static const IPAddress WIFI_DNS2    ( 8,  8,  8,  8); // Google DNS fallback
#endif
